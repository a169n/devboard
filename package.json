{
  "name": "devboard",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @devboard/api\" \"npm run dev -w @devboard/web\"",
    "build": "npm run build -w @devboard/api && npm run build -w @devboard/web",
    "lint": "npm run lint -w @devboard/api && npm run lint -w @devboard/web",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "npm run prisma:migrate -w @devboard/api",
    "db:generate": "npm run prisma:generate -w @devboard/api",
    "db:seed": "npm run prisma:seed -w @devboard/api"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
